# OpenAI-compatible AI provider (required)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o

# Tool-loop step limit per Processing Cycle (optional, default 50)
AI_MAX_STEPS=50

# Todoist Board (required)
TODOIST_API_TOKEN=
TODOIST_PROJECT_ID=

# HTTP server (optional, default 3000)
PORT=3000

# Log level (optional, default info; valid: trace, debug, info, warn, error, fatal, silent)
LOG_LEVEL=info

# Telemetry (optional, default off)
# Set TELEMETRY_ENABLED=true to emit OTel traces for each Processing Cycle.
# When enabled, OTEL_SERVICE_NAME and OTEL_EXPORTER_OTLP_ENDPOINT are required.
TELEMETRY_ENABLED=false
OTEL_SERVICE_NAME=shrimp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer token,X-Custom=value
# TELEMETRY_RECORD_INPUTS=true
# TELEMETRY_RECORD_OUTPUTS=true
# OTel internal diagnostics (forwarded through pino). Default WARN; set to
# DEBUG when investigating why spans are not reaching the collector.
# OTEL_LOG_LEVEL=warn

# Channels (optional, default off)
# Set CHANNELS_ENABLED=true to mount inbound Channel webhooks (e.g. Telegram)
# and to enable Session-backed ChannelJob processing. When enabled,
# TELEGRAM_BOT_TOKEN and TELEGRAM_WEBHOOK_SECRET are required; when disabled,
# they are neither read nor validated.
CHANNELS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Filesystem directory holding Session state (state.json + sessions/<id>.jsonl).
# Optional; defaults to ~/.shrimp. Created at startup when Channels are enabled;
# process fails fast if creation fails.
# SHRIMP_STATE_DIR=
