{
  "name": "@aotoki/autonoe-shrimp",
  "version": "1.0.0",
  "description": "Event-driven background agent for Todoist tasks",
  "type": "module",
  "main": "dist/server.mjs",
  "scripts": {
    "dev": "tsdown --watch --onSuccess \"node dist/server.mjs\"",
    "build": "tsdown",
    "start": "node dist/server.mjs",
    "heartbeat": "node dist/heartbeat.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=100",
    "docker:shell": "docker compose exec shrimp sh",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build --watch",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down"
  },
  "keywords": [],
  "author": "Aotokitsuruya",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@doist/todoist-sdk": "^9.0.0",
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "ai": "^6.0.158",
    "dotenv": "^17.4.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.14",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "msw": "^2.13.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "unplugin-raw": "^0.7.0",
    "vitest": "^4.1.4"
  }
}
